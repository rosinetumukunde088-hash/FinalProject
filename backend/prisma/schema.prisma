generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserCategory {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  role          UserRole        @default(USER)
  category      UserCategory    @default(BEGINNER)
  phone         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  behaviors     UserBehavior[]
  adaptations   Adaptation[]
}

model Product {
  id          String          @id @default(uuid())
  name        String
  nameRw      String?
  description String
  descriptionRw String?
  price       Float
  category    String
  imageUrl    String?
  stock       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model UserBehavior {
  id                String    @id @default(uuid())
  userId            String
  clickLatency      Int?
  wrongClicks       Int?
  timeSpent         Int?
  repeatedActions   Int?
  navigationPattern String?
  page              String?
  deviceInfo        String?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Adaptation {
  id                String        @id @default(uuid())
  userId            String
  userCategory      UserCategory
  simplifiedLayout  Boolean       @default(false)
  kinyarwandaEnabled Boolean     @default(false)
  audioPromptsEnabled Boolean    @default(false)
  fontSize          String        @default("medium")
  highContrast      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Translation {
  id                  String    @id @default(uuid())
  sourceText          String
  kinyarwandaText     String
  context             String?
  createdAt           DateTime  @default(now())

  @@index([sourceText])
}

model AudioPrompt {
  id            String    @id @default(uuid())
  text          String
  audioUrl      String?
  language      String    @default("rw")
  createdAt     DateTime  @default(now())
}

model AiPrediction {
  id            String        @id @default(uuid())
  userId        String
  clickLatency  Int?
  wrongClicks   Int?
  timeSpent     Int?
  repeatedActions Int?
  predictedCategory UserCategory
  confidence    Float?
  createdAt     DateTime      @default(now())

  @@index([userId])
}

model AdminAction {
  id          String    @id @default(uuid())
  adminId     String
  action      String
  targetId    String?
  details     String?
  createdAt   DateTime  @default(now())

  @@index([adminId])
}
