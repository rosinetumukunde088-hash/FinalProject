generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
}
enum UserRole {
  USER
  ADMIN
  TRADER
  MANAGER
}

enum UserCategory {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum OrderStatus {
  PAID
  CANCELLED
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  role          UserRole        @default(USER)
  category      UserCategory    @default(BEGINNER)
  isActive      Boolean         @default(true)
  phone         String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  behaviors     UserBehavior[]
  adaptations   Adaptation[]
  orders        Order[]
  products      Product[]
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  nameRw    String?
  nameSw    String?
  createdAt DateTime @default(now())
}

model Product {
  id            String          @id @default(uuid())
  name          String
  nameRw        String?
  nameSw        String?
  description   String
  descriptionRw String?
  descriptionSw String?
  price         Float
  category      String
  imageUrl      String?
  images        String[]
  stock         Int             @default(0)
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  createdBy     User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  total         Float
  paymentMethod String
  status        OrderStatus @default(PAID)
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String?
  name      String
  imageUrl  String?
  price     Float
  quantity  Int

  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model UserBehavior {
  id                String    @id @default(uuid())
  userId            String
  clickLatency      Int?
  wrongClicks       Int?
  timeSpent         Int?
  repeatedActions   Int?
  navigationPattern String?
  page              String?
  deviceInfo        String?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Adaptation {
  id                String        @id @default(uuid())
  userId            String
  userCategory      UserCategory
  simplifiedLayout  Boolean       @default(false)
  kinyarwandaEnabled Boolean     @default(false)
  audioPromptsEnabled Boolean    @default(false)
  fontSize          String        @default("medium")
  highContrast      Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Translation {
  id                  String    @id @default(uuid())
  sourceText          String
  kinyarwandaText     String
  context             String?
  createdAt           DateTime  @default(now())

  @@index([sourceText])
}

model AudioPrompt {
  id            String    @id @default(uuid())
  text          String
  audioUrl      String?
  language      String    @default("rw")
  createdAt     DateTime  @default(now())
}

model AiPrediction {
  id            String        @id @default(uuid())
  userId        String
  clickLatency  Int?
  wrongClicks   Int?
  timeSpent     Int?
  repeatedActions Int?
  predictedCategory UserCategory
  confidence    Float?
  createdAt     DateTime      @default(now())

  @@index([userId])
}

model AdminAction {
  id          String    @id @default(uuid())
  adminId     String
  action      String
  targetId    String?
  details     String?
  createdAt   DateTime  @default(now())

  @@index([adminId])
}
